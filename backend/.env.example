# ── Application ──────────────────────────────────────────────────
# development | production | test
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false

# ── Security (REQUIRED in production) ────────────────────────────
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
# Auth cookies (httpOnly JWT). In production over HTTPS set COOKIE_SECURE=true.
# For a separate front-end domain in production use COOKIE_SAMESITE=none (needs HTTPS).
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ── Database — MongoDB Atlas ─────────────────────────────────────
# Atlas SRV string, e.g.
#   mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# Local dev default is a MongoDB on localhost:27017.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=multimodal_ai

# ── HTTP ─────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
MAX_UPLOAD_SIZE_MB=25

# ── Web search provider ──────────────────────────────────────────
SERPER_API_KEY=568a9b1308a6f8ef3ffbd595aa8c09f3edee0704
SERPER_BASE_URL=https://google.serper.dev

# ── ML features ──────────────────────────────────────────────────
ENABLE_LOCAL_LLM=true
ENABLE_QUERY_EXPANSION=true
TEXT_EMBEDDING_MODEL=all-MiniLM-L6-v2
WHISPER_MODEL=base
# Local fallback model — 0.5B is much faster on CPU than 1.5B.
LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
LLM_MAX_NEW_TOKENS=320

# ── Fast generation via Groq (recommended) ──────────────────────
# Get a free key at https://console.groq.com/keys — chat replies then take
# well under a second instead of minutes on CPU. Leave blank to use the
# local model above.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── RAG tuning ───────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RAG_TOP_K=6
