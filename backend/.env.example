# ── Application ──────────────────────────────────────────────────
# development | production | test
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false

# ── Security (REQUIRED in production) ────────────────────────────
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
# Auth cookies (httpOnly JWT). In production over HTTPS set COOKIE_SECURE=true.
# For a separate front-end domain in production use COOKIE_SAMESITE=none (needs HTTPS).
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ── Database — MongoDB Atlas ─────────────────────────────────────
# Atlas SRV string, e.g.
#   mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# Local dev default is a MongoDB on localhost:27017.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=multimodal_ai

# ── HTTP ─────────────────────────────────────────────────────────
# Exact frontend origin(s), comma separated. Never "*" — the API sends
# credentialed cookies. In production list your deployed origin, e.g.
#   CORS_ORIGINS=https://neuron.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
MAX_UPLOAD_SIZE_MB=25
# Number of proxies/CDNs in front of this app (Render, Vercel, nginx = 1).
# Leave 0 when directly exposed: trusting X-Forwarded-For without a proxy in
# front lets any client forge its IP and evade rate limiting.
TRUSTED_PROXY_HOPS=0

# ── Login throttling ─────────────────────────────────────────────
# Failed sign-ins are counted per (client IP + email) and locked out for the
# window once the limit is hit. A successful sign-in clears the count.
LOGIN_MAX_FAILURES=8
LOGIN_FAILURE_WINDOW_SECONDS=900

# ── Web search provider ──────────────────────────────────────────
# Get a key at https://serper.dev — this file is committed, so it must never
# hold a real one. Put the real value in backend/.env (which is gitignored).
SERPER_API_KEY=
SERPER_BASE_URL=https://google.serper.dev

# ── ML features ──────────────────────────────────────────────────
ENABLE_LOCAL_LLM=true
ENABLE_QUERY_EXPANSION=true
TEXT_EMBEDDING_MODEL=all-MiniLM-L6-v2
WHISPER_MODEL=base
# Local fallback model — 0.5B is much faster on CPU than 1.5B.
LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
LLM_MAX_NEW_TOKENS=320

# ── Fast generation via Groq (recommended) ──────────────────────
# Get a free key at https://console.groq.com/keys — chat replies then take
# well under a second instead of minutes on CPU. Leave blank to use the
# local model above.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── RAG tuning ───────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RAG_TOP_K=6

# ── Mail service (feedback notifications) ────────────────────────
# Feedback from the site footer is emailed to FEEDBACK_TO_EMAIL.
# Gmail requires an APP PASSWORD (not your normal password):
#   Google Account → Security → 2-Step Verification → App passwords
ENABLE_EMAIL=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=
FEEDBACK_TO_EMAIL=you@gmail.com
MAIL_FROM_NAME=Neuron

# ── Cloudinary (avatar image uploads) ────────────────────────────
# Dashboard → https://console.cloudinary.com  (Settings → API Keys)
# The browser uploads directly to Cloudinary using a signature minted by
# this server, so the secret below never reaches the client.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=neuron/avatars
CLOUDINARY_MAX_IMAGE_MB=5
